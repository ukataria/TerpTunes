<%- include('partials/header') %>

<section class="section edit-section">
  <h1>Edit Track</h1>

  <div class="edit-layout">
    <% if (track.albumImage) { %>
      <img src="<%= track.albumImage %>" alt="<%= track.albumName %>" class="edit-img" />
    <% } %>

    <div class="edit-details">
      <h2><%= track.trackName %></h2>
      <p class="card-artist"><%= track.artistName %></p>
      <p class="card-album"><%= track.albumName %></p>
    </div>
  </div>

  <form action="/collection/edit/<%= track._id %>" method="POST" class="edit-form">
    <label for="rating">Rating</label>
    <div class="star-rating-input" id="star-rating">
      <% for (let i = 1; i <= 5; i++) { %>
        <span
          class="star-input <%= i <= track.rating ? 'star-input--active' : '' %>"
          data-value="<%= i %>"
          onclick="setRating(<%= i %>)"
        >&#9733;</span>
      <% } %>
      <input type="hidden" name="rating" id="rating-value" value="<%= track.rating %>" />
    </div>

    <label for="notes">Notes</label>
    <textarea name="notes" id="notes" rows="4" placeholder="Add your thoughts about this track..."><%= track.notes %></textarea>

    <div class="form-actions">
      <button type="submit" class="btn btn-save">Save Changes</button>
      <a href="/collection" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</section>

<%- include('partials/footer') %>
